generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id              String   @id @default(uuid())
  title           String
  sourceFilename  String
  importedAt      DateTime @default(now())

  totalAxes       Int
  totalBlocs      Int
  totalArticles   Int
  totalMots       Int
  totalCaracteres Int

  nodes           Node[]
  analysis        DocumentAnalysis?

  @@map("documents")
}

model Node {
  id          String   @id @default(uuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  level       Int
  parentId    String?
  parent      Node?    @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    Node[]   @relation("NodeChildren")

  position    Int
  titre       String
  slug        String
  indexGlobal Int?
  connexe     Json?
  mots        Int?
  caracteres  Int?

  paragraphs  Paragraph[]

  @@index([documentId])
  @@index([parentId])
  @@map("nodes")
}

enum ParagraphType {
  TEXT
  LIST
}

model Paragraph {
  id       String        @id @default(uuid())
  nodeId   String
  node     Node          @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  position Int
  type     ParagraphType @default(TEXT)
  ordered  Boolean?
  content  String

  @@index([nodeId])
  @@map("paragraphs")
}

// Analyses d'un document — une ligne par document, chaque volet remplacé à
// son recalcul (pas d'historique conservé). Volets indépendants, chacun
// nullable tant qu'il n'a pas été calculé :
// - lexical (+ lexicalComputedAt) : analyse spaCy via nlp-service/ (stats,
//   entités nommées, nuage de lemmes, modèle inclus dans le Json). Le nuage
//   de mots (lemmes filtrables par POS) est une facette de ce volet.
model DocumentAnalysis {
  id            String   @id @default(uuid())
  documentId    String   @unique
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  computedAt    DateTime @default(now())

  // registres : colonne INUTILISÉE — référencée nulle part dans le code
  // (backend comme frontend), et l'intention d'origine s'est perdue. Laissée
  // en place volontairement le temps de trancher : elle ne coûte rien tant
  // qu'elle reste nulle. Ne pas s'en servir comme fourre-tout au motif qu'elle
  // est libre (la typologie des styles, par exemple, aura sa propre colonne) —
  // soit on retrouve son usage et on la documente ici, soit on la supprime.
  registres     Json?

  lexical           Json?
  lexicalComputedAt DateTime?

  // semantic : proximité sémantique entre nœuds (voisins top-K par nœud),
  // calculée à partir des embeddings sentence-camembert (cf. EmbeddingCache).
  semantic           Json?
  semanticComputedAt DateTime?

  // topics : thèmes BERTopic sur segments + répartition par axe (job
  // asynchrone côté nlp-service, persisté à la fin du polling).
  topics           Json?
  topicsComputedAt DateTime?

  @@map("document_analyses")
}

// Cache d'embeddings adressé par contenu (sha256 du texte brut d'un
// paragraphe) et non par paragraphId : les entrées survivent aux réimports/
// suppressions de documents (pas de FK, pas de cascade) et les paragraphes
// identiques partagent une entrée. Une réanalyse ne recalcule que les
// paragraphes dont le texte a changé. Pas de purge automatique — à prévoir
// si la table devient encombrante.
model EmbeddingCache {
  id          String   @id @default(uuid())
  model       String
  contentHash String
  vector      Json
  createdAt   DateTime @default(now())

  @@unique([model, contentHash])
  @@map("embedding_cache")
}
