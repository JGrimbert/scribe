generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id              String   @id @default(uuid())
  title           String
  sourceFilename  String
  importedAt      DateTime @default(now())

  totalAxes       Int
  totalBlocs      Int
  totalArticles   Int
  totalMots       Int
  totalCaracteres Int

  // styleInventory : styles et surlignages relevés dans le .odt à l'import
  // (StyleInventory). Reconstructible depuis DocumentSource, mais capturé ici
  // parce que le recalculer à chaque lecture reviendrait à reparser le ZIP
  // pour afficher un tableau.
  styleInventory  Json?
  // styleTypology : le rôle décidé pour chaque style (DocumentTypology).
  // NULL tant que l'utilisateur n'a pas tranché — les suggestions ne sont
  // jamais persistées à sa place (cf. typology.ts). Un style apparu depuis la
  // dernière décision rend la typologie « non arbitrée » à nouveau.
  styleTypology   Json?
  // validationRules : ce qu'un chapitre doit contenir pour être réputé
  // conforme (DocumentRules). NULL = les règles par défaut s'appliquent
  // (cf. rules.ts) — pas besoin de configurer pour que le dashboard dise
  // quelque chose. Indicatif : la conformité ne bloque pas la validation
  // manuelle, elle l'informe.
  validationRules Json?

  // Les deux bornes du livre TELLES QU'ELLES ONT ÉTÉ VALIDÉES au dernier
  // commit (index de titre dans l'outline, cf. ImportCorrections). Elles
  // n'étaient stockées nulle part : `suggestedStructureStartIndex` est une
  // SUGGESTION recalculée à chaque preview, pas la borne courante — on ne
  // pouvait donc pas rouvrir la calibration là où l'utilisateur l'avait
  // laissée, ni interpréter un déplacement relatif de borne.
  // Nullables : les documents importés avant ces colonnes ne les portent pas.
  structureStartIndex Int?
  structureEndIndex   Int?

  // liminaire / final : les deux bouts du livre qui ne sont pas de la structure
  // (page de titre, auteur, dédicace ; table des matières, index, glossaire),
  // sous forme de TexteEntry[] — ils portent donc styleName et highlight, ce
  // qu'un simple tableau de chaînes ne faisait pas.
  //
  // Des colonnes Json et pas des Node/Paragraph, délibérément : ces zones ne
  // sont ni éditées, ni validées, ni analysées. Leur donner des nœuds les ferait
  // entrer dans completeness, conformity et l'arbre de StructureView, où elles
  // n'ont rien à faire. Même nature que styleInventory : un relevé d'import, lu
  // en bloc.
  //
  // NULL = document importé avant ces colonnes : le remplir suppose de rejouer
  // le parse (possible depuis DocumentSource, sauf pour les documents antérieurs
  // à cette table — pour eux, seul un réimport).
  liminaire       Json?
  final           Json?

  // liminaireConfig : le tagging des pages liminaires décidé par l'utilisateur
  // — { [pageKey]: { type, side } }, cf. documents/liminaire-config.ts et
  // frontend script/liminaire. Séparé des entrées `liminaire` (qu'un reparse
  // régénère) : c'est une DÉCISION, pas un relevé. Keyé par le hash du texte de
  // la page pour survivre au recalibrage. NULL = rien tagué.
  liminaireConfig Json?

  // styleDefaults : réglages typographiques GÉNÉRAUX décidés par l'utilisateur,
  // appliqués par-dessus les styles du .odt — { hyphenation: { global } }, cf.
  // documents/style-defaults.ts. Première propriété : la césure (défaut global de
  // la cascade Folio, cf. frontend script/folioStyles). Séparé de styleInventory
  // (un relevé d'import) : c'est une DÉCISION, même nature que liminaireConfig.
  // NULL = aucun réglage (la cascade retombe sur les seules valeurs du .odt).
  styleDefaults   Json?

  nodes           Node[]
  analysis        DocumentAnalysis?
  source          DocumentSource?

  @@map("documents")
}

// Le .odt d'origine, conservé tel quel. Une table à part et NON une colonne
// `Bytes` sur Document : Prisma ramène toutes les colonnes scalaires quand le
// `select` n'est pas explicite, et un blob sur Document ferait charger
// plusieurs Mo à chaque findUnique — y compris ceux qui ne veulent qu'un
// titre. Ici, il faut le demander pour l'avoir.
//
// Ce que ça débloque : la calibration d'import redevient rejouable (elle était
// à sens unique, le buffer ne vivant que le temps d'une Map en mémoire), et
// tout enrichissement futur du parseur s'applique rétroactivement au lieu
// d'exiger un réimport manuel.
//
// NULL = document importé avant cette table : lui seul reste dans l'ancien
// régime (pas de recalibration possible sans réimport).
model DocumentSource {
  id         String   @id @default(uuid())
  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  bytes      Bytes
  // Dérivable de `bytes`, mais le lire supposerait justement de charger le
  // blob qu'on cherche à ne pas charger.
  sizeBytes  Int
  storedAt   DateTime @default(now())

  @@map("document_sources")
}

model Node {
  id          String   @id @default(uuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  level       Int
  parentId    String?
  parent      Node?    @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    Node[]   @relation("NodeChildren")

  position    Int
  titre       String
  slug        String
  indexGlobal Int?
  connexe     Json?
  mots        Int?
  caracteres  Int?

  // Style ODT EFFECTIF du titre (« Heading 3 », décodé) : clé de la feuille
  // `visuals` côté Folio pour un titre fidèle au .odt (centrage, corps). Distinct
  // de Paragraph.styleName (un titre n'est pas un paragraphe). Nullable : les
  // documents importés avant cette colonne n'en ont pas (seul un réimport la
  // remplit).
  styleName    String?
  // Numéro de chapitre AUTO reconstruit du `<text:outline-style>` (« I. »,
  // « (a) »…). Porté par le nœud — pas un compteur CSS, qui repartirait à I.
  // dès qu'un article est ouvert seul. Nullable (idem).
  outlineNumber String?

  paragraphs  Paragraph[]
  validation  NodeValidation?

  @@index([documentId])
  @@index([parentId])
  @@map("nodes")
}

// Validation manuelle d'un chapitre — un FAIT UTILISATEUR, pas une propriété
// d'import ni une analyse. D'où une table à part plutôt qu'une colonne sur
// Node (qu'un réimport charrierait) ou un volet de DocumentAnalysis (écrasé à
// chaque recalcul). Une ligne = « j'ai relu ce chapitre, il est bon ».
//
// contentHash : sha256 du texte BRUT du nœud au moment de la validation
// (plainNodeText — balises retirées, cf. nodeContentHash). Si le texte change
// ensuite, le hash ne correspond plus et le chapitre bascule en « périmé »
// plutôt que d'être silencieusement dévalidé : la relecture est à refaire, et
// ça se voit. Le passage par le texte brut est délibéré — reformater un mot en
// gras ne périme pas une relecture, réécrire une phrase si.
model NodeValidation {
  id          String   @id @default(uuid())
  nodeId      String   @unique
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  validatedAt DateTime @default(now())
  contentHash String

  @@map("node_validations")
}

enum ParagraphType {
  TEXT
  LIST
}

model Paragraph {
  id       String        @id @default(uuid())
  nodeId   String
  node     Node          @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  position Int
  type     ParagraphType @default(TEXT)
  ordered  Boolean?
  content  String

  // Style ODT EFFECTIF (parent résolu, décodé : « Citation paragraphe », pas
  // « P26 ») — c'est la clé de styleTypology. Nullable : les documents importés
  // avant cette colonne n'en ont pas, et le .odt n'étant pas conservé, seule
  // une réimportation peut la remplir.
  styleName String?
  // Surlignage du paragraphe ENTIER (couleur brute). Les surlignages inline
  // vivent dans `content`, en <mark data-hl="…">.
  highlight String?

  @@index([nodeId])
  @@map("paragraphs")
}

// Analyses d'un document — une ligne par document, chaque volet remplacé à
// son recalcul (pas d'historique conservé). Volets indépendants, chacun
// nullable tant qu'il n'a pas été calculé :
// - lexical (+ lexicalComputedAt) : analyse spaCy via nlp-service/ (stats,
//   entités nommées, nuage de lemmes, modèle inclus dans le Json). Le nuage
//   de mots (lemmes filtrables par POS) est une facette de ce volet.
model DocumentAnalysis {
  id            String   @id @default(uuid())
  documentId    String   @unique
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  computedAt    DateTime @default(now())

  // registres : colonne INUTILISÉE — référencée nulle part dans le code
  // (backend comme frontend), et l'intention d'origine s'est perdue. Laissée
  // en place volontairement le temps de trancher : elle ne coûte rien tant
  // qu'elle reste nulle. Ne pas s'en servir comme fourre-tout au motif qu'elle
  // est libre (la typologie des styles, par exemple, aura sa propre colonne) —
  // soit on retrouve son usage et on la documente ici, soit on la supprime.
  registres     Json?

  lexical           Json?
  lexicalComputedAt DateTime?

  // semantic : proximité sémantique entre nœuds (voisins top-K par nœud),
  // calculée à partir des embeddings sentence-camembert (cf. EmbeddingCache).
  semantic           Json?
  semanticComputedAt DateTime?

  // topics : thèmes BERTopic sur segments + répartition par axe (job
  // asynchrone côté nlp-service, persisté à la fin du polling).
  topics           Json?
  topicsComputedAt DateTime?

  @@map("document_analyses")
}

// Cache d'embeddings adressé par contenu (sha256 du texte brut d'un
// paragraphe) et non par paragraphId : les entrées survivent aux réimports/
// suppressions de documents (pas de FK, pas de cascade) et les paragraphes
// identiques partagent une entrée. Une réanalyse ne recalcule que les
// paragraphes dont le texte a changé. Pas de purge automatique — à prévoir
// si la table devient encombrante.
model EmbeddingCache {
  id          String   @id @default(uuid())
  model       String
  contentHash String
  vector      Json
  createdAt   DateTime @default(now())

  @@unique([model, contentHash])
  @@map("embedding_cache")
}
